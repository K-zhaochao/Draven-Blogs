# ============================================================
# Draven-Blogs 环境变量配置
# ============================================================
# 复制本文件为 .env 并填入实际值
#
# 注意：.env 已加入 .gitignore，不会提交到仓库
# ============================================================

# TinaCMS Cloud 认证（必填）
# 在 https://app.tina.io 创建项目后获取
TINA_CLIENT_ID=
TINA_TOKEN=

# GitHub Personal Access Token（可选）
# 用于提高 sync-projects.mjs 的 API rate limit
# 不填也能运行，但频繁调用时可能触发限流
GITHUB_TOKEN=

{
  "type": "module",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdownlint-cli": "^0.48.0",
    "medium-zoom": "^1.1.0",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.2",
    "vue": "^3.5.33"
  },
  "dependencies": {
    "@tinacms/cli": "^2.2.6",
    "artalk": "^2.9.1",
    "gray-matter": "^4.0.3",
    "lucide-vue-next": "^0.577.0",
    "markdown-it": "^14.2.0",
    "sanitize-html": "^2.17.4",
    "tinacms": "^3.7.6"
  },
  "scripts": {
    "sync:notes": "node scripts/sync.mjs",
    "sync:projects": "node scripts/sync-projects.mjs",
    "sync": "npm run sync:notes && npm run sync:projects",
    "tina:dev": "tinacms dev -c \"vitepress dev docs\"",
    "tina:build": "tinacms build",
    "dev": "npm run sync && tinacms dev -c \"vitepress dev docs\"",
    "build": "npm run sync && tinacms build && vitepress build docs",
    "build:strict": "cross-env STRICT_LINKS=1 npm run build",
    "preview": "vitepress preview docs",
    "watch": "npm run sync:notes -- --watch",
    "lint:md": "npx markdownlint \"**/*.md\" --ignore node_modules --ignore docs/notes --ignore tina",
    "check": "npm run lint:md"
  }
}

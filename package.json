    "medium-zoom": "^1.1.0",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.2",
    "vue": "^3.5.33"
  },
  "dependencies": {
    "tinacms": "latest",
    "@tinacms/cli": "latest"
  },
  "scripts": {
    "sync": "node scripts/sync.mjs",
